MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=mohiom_db
DEBUG=False
CORS_ORIGINS=["http://localhost:3000"]

# 9Router (optional text generation provider)
NINE_ROUTER_URL=https://your-tunnel.trycloudflare.com/v1
NINE_ROUTER_API_KEY=your_9router_api_key
NINE_ROUTER_MODEL=kr/claude-sonnet-4.5
NINE_ROUTER_TIMEOUT_SECONDS=60

# Cloudflare R2 (S3-compatible object storage for generated images)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=mohiom-images
R2_PUBLIC_URL_BASE=https://pub-xxxxxxxxxxxx.r2.dev

# Production CORS/auth overrides (uncomment and adapt for deployment):
# CORS_ORIGINS=["https://mohiom.me","https://www.mohiom.me"]
# AUTH_FRONTEND_URL=https://mohiom.me
# AUTH_BACKEND_URL=https://<your-backend-host>
# AUTH_COOKIE_SECURE=true
# AUTH_COOKIE_SAMESITE=none   # required cross-origin; must pair with SECURE=true

# Resend (transactional email API for password reset emails)
# Sign up at https://resend.com — free tier is 100 emails/day.
# RESEND_FROM must be on a Resend-verified sending domain for production use.
# The sandbox address below only delivers to the Resend account owner's own
# verified email — fine for local testing, not for real users.
RESEND_API_KEY=your_resend_api_key
RESEND_FROM=onboarding@resend.dev
