MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=mohiom_db
DEBUG=False
CORS_ORIGINS=["http://localhost:3000"]

# 9Router (optional text generation provider)
NINE_ROUTER_URL=https://your-tunnel.trycloudflare.com/v1
NINE_ROUTER_API_KEY=your_9router_api_key
NINE_ROUTER_MODEL=kr/claude-sonnet-4.5
NINE_ROUTER_TIMEOUT_SECONDS=60

# Cloudflare R2 (S3-compatible object storage for generated images)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=mohiom-images
R2_PUBLIC_URL_BASE=https://pub-xxxxxxxxxxxx.r2.dev
